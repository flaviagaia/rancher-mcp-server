# Copie para .env e preencha (o .env está no .gitignore, nunca commite)
RANCHER_URL=https://rancher.example.com
RANCHER_TOKEN=token-xxxxx:yyyyyyyyyyyy

# Ações de escrita (scale/redeploy) desabilitadas por padrão
RANCHER_MCP_ALLOW_WRITE=false
RANCHER_MCP_MAX_REPLICAS=20

# Só desative em labs com certificado self-signed
RANCHER_VERIFY_TLS=true
